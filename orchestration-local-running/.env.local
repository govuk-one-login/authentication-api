AUTHENTICATION_BACKEND_URI=http://host.docker.internal:4401/auth-stub/
AUTHENTICATION_AUTHORIZATION_CALLBACK_URI=
AUTH_SIGNING_KEY_ALIAS=alias/local-auth-token-signing-key
ORCH_TO_AUTH_ENCRYPTION_KEY_PARAM=local-auth-public-encryption-key
