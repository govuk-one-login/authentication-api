# IPV
IPV_AUTHORISATION_URI=http://localhost:4401/ipv-stub/authorize
IPV_BACKEND_URI=http://host.docker.internal:4401/ipv-stub/
IPV_AUDIENCE=http://localhost:4401
IPV_AUTHORISATION_CALLBACK_URI=http://localhost:4400/ipv-callback
IPV_AUTHORISATION_CLIENT_ID=authOrchestrator
IPV_TOKEN_SIGNING_KEY_ALIAS=alias/local-ipv-token-signing-key
IPV_JWKS_URL=http://host.docker.internal:4401/ipv-stub/.well-known/jwks.json

# Doc App
DOC_APP_AUTHORISATION_URI=http://localhost:4401/ipv-stub/authorize
DOC_APP_BACKEND_URI=
DOC_APP_AUTHORISATION_CALLBACK_URI=
DOC_APP_AUTHORISATION_CLIENT_ID=doc-app
DOC_APP_JWKS_URL=
DOC_APP_SIGNING_KEY_ALIAS=alias/local-doc-app-token-signing-key
DOC_APP_CRI_DATA_V2_ENDPOINT=
DOC_APP_AUD=
DOC_APP_DOMAIN=

# SPOT
SPOT_REQUEST_QUEUE_URL=http://sqs.eu-west-2.localhost:45678/000000000000/local-spot-request-queue
SPOT_RESPONSE_QUEUE_URL=http://sqs.eu-west-2.localhost:45678/000000000000/local-spot-response-queue

# Features
IDENTITY_ENABLED=true
SEND_STORAGE_TOKEN_TO_IPV_ENABLED=true
USE_SYNC_WAIT_FOR_SPOT=true
NEW_SPOT_REQUEST_QUEUE_WRITING=true
