# Main config
AWS_ACCESS_KEY_ID=local
AWS_EMF_ENVIRONMENT=Local
AWS_REGION=eu-west-2
AWS_SECRET_ACCESS_KEY=local
AWS_XRAY_CONTEXT_MISSING=IGNORE_ERROR
BACK_CHANNEL_LOGOUT_QUEUE_URI=http://sqs.eu-west-2.localhost:45678/000000000000/local-backchannel-logout-queue
DOMAIN_NAME=localhost # Used for cookie domain!
DYNAMO_ENDPOINT=http://host.docker.internal:8000
ENVIRONMENT=local
EXTERNAL_TOKEN_SIGNING_KEY_ALIAS=alias/local-external-token-signing-key
EXTERNAL_TOKEN_SIGNING_KEY_RSA_ALIAS=
NEXT_EXTERNAL_TOKEN_SIGNING_KEY_ALIAS_V2=alias/local-external-token-signing-key
INTERNAl_SECTOR_URI=https://identity.local.account.gov.uk/
LOCALSTACK_ENDPOINT=http://host.docker.internal:45678
OIDC_API_BASE_URL=http://host.docker.internal:4400/
OIDC_FRONTEND_BASE_URL=http://localhost:4400/
OIDC_SERVICE_DOMAIN=localhost
PORT=4400
ORCH_CLIENT_ID=orchestrationAuth
REDIS_KEY=session
SESSION_COOKIE_ATTRIBUTES="HttpOnly;"
SQS_ENDPOINT=http://host.docker.internal:45678
STORAGE_TOKEN_SIGNING_KEY_ALIAS=alias/local-storage-token-signing-key
TRACING_ENABLED=false
TXMA_AUDIT_QUEUE_URL=local-txma-audit-queue

# Auth
