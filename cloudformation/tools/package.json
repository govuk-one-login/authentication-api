{
  "name": "di-authentication-api",
  "description": "User Authetication one login",
  "version": "0.0.1",
  "type": "module",
  "devDependencies": {
    "node-cache": "^5.1.2",
    "node-loader": "^2.0.0",
    "nodemon": "^3.0.1",
    "npm-run-all": "^4.1.5",
    "prettier": "^2.7.1",
    "yaml": "^2.1.3"
  },
  "scripts": {
    "build:template": "node ./src/tools/yaml-import.js",
    "checkov": "checkov --quiet -f template.yaml --framework cloudformation --external-checks-git git@github.com:alphagov/di-devplatform-checkov-hook.git//src/gds_digitalidentity_checkovhook/custom_policies",
    "sam:build": "npm run build && npm run build:template && npm run checkov && sam build"
  },
  "lint-staged": {
    "*.{js,json,ts,yaml,yml}": "prettier --write"
  }
}
